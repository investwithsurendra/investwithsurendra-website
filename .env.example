# ==============================================
# INVEST WITH SURENDRA — Environment Variables
# ==============================================
# Copy this file to .env and fill in the real values.
# On Vercel, add these under Project Settings → Environment Variables.

# ---------- Database ----------
# For local dev: mongodb://localhost:27017
# For production: use MongoDB Atlas free tier connection string
# Sign up: https://www.mongodb.com/cloud/atlas
MONGO_URL=mongodb://localhost:27017
DB_NAME=invest_with_surendra

# ---------- Public Base URL ----------
# Your production domain (used for SEO canonical, sitemap, OG tags)
NEXT_PUBLIC_BASE_URL=https://www.investwithsurendra.com

# ---------- CORS ----------
CORS_ORIGINS=*

# ==============================================
# ADMIN AUTHENTICATION
# ==============================================
ADMIN_EMAIL=surendra.kumar.ctl@gmail.com
# IMPORTANT: If password contains "#" wrap it in double quotes
ADMIN_PASSWORD="Surendra@2026#IWS"
# Generate a random 64-char string for production. Use: openssl rand -hex 32
AUTH_SECRET=change-this-to-a-random-64-character-secret-in-production

# ==============================================
# CLOUDINARY (media upload)
# ==============================================
# Get FREE keys at: https://cloudinary.com (25 GB free tier)
# Dashboard → Account Details → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==============================================
# RESEND (lead email notifications)
# ==============================================
# Get FREE key at: https://resend.com (3000 emails/month free)
RESEND_API_KEY=
# For testing you can use resend's shared address:
RESEND_FROM_EMAIL=onboarding@resend.dev
# Once you verify your domain, use: leads@investwithsurendra.com
NOTIFICATION_EMAIL=surendra.kumar.ctl@gmail.com

# ==============================================
# ANALYTICS & TRACKING (all optional; add anytime)
# ==============================================
# Google Analytics 4 (starts with G-)
NEXT_PUBLIC_GA_ID=
# Meta / Facebook Pixel ID (numeric)
NEXT_PUBLIC_META_PIXEL_ID=
# Google Ads Conversion (starts with AW-)
NEXT_PUBLIC_GADS_ID=
NEXT_PUBLIC_GADS_LABEL=
# Google Search Console verification code
NEXT_PUBLIC_GSC_VERIFICATION=

# ==============================================
# WHATSAPP
# ==============================================
# International format without "+" (e.g. 919352835139 for +91 9352835139)
NEXT_PUBLIC_WHATSAPP_NUMBER=919352835139
